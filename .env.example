# Required: your OpenAI API key (used for resume tailoring + analysis).
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Optional: where generated resumes are written. Relative paths resolve
# against the app folder; defaults to ./resumes.
OUTPUT_ROOT=resumes

# Optional model / timeout overrides
# OPENAI_ANALYSIS_MODEL=gpt-4o-mini
# OPENAI_RESUME_MODEL=gpt-5-mini
# OPENAI_ANALYSIS_TIMEOUT_SECONDS=120
# OPENAI_RESUME_TIMEOUT_SECONDS=180

# Optional: override the DOCX style template used for formatting
# RESUME_TEMPLATE_PATH=assets/resume_template.docx
